generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  name        String?
  email       String?      @unique
  image       String?
  phone       String?
  events      Event[]
  attendances Attendance[]
  joinRequests JoinRequest[]
  notifications Notification[]
}

model Event {
  id                  String       @id
  category            String       @default("COFFEE")
  customCategoryTitle String?
  title               String
  description         String?
  address             String?
  dateISO             String?
  contactMethod       String       @default("NONE")
  contactVisibility   String       @default("SIGNED_IN_ONLY")
  whatsappInviteUrl   String?
  lat                 Float
  lng                 Float
  createdAtISO        String
  userId              String?
  user                User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  attendances         Attendance[]
  joinRequests        JoinRequest[]

  @@index([createdAtISO])
  @@index([lat, lng])
  @@index([lat])
  @@index([lng])
  @@index([userId])
}

model Attendance {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model JoinRequest {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  eventId   String?
  actorId   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}
