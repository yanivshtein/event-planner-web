generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id           String  @id
  title        String
  description  String?
  address      String?
  dateISO      String?
  lat          Float
  lng          Float
  createdAtISO String

  @@index([createdAtISO])
  @@index([lat, lng])
}
